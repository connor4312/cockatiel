{
  "name": "cockatiel",
  "version": "3.2.1",
  "description": "A resilience and transient-fault-handling library that allows developers to express policies such as Backoff, Retry, Circuit Breaker, Timeout, Bulkhead Isolation, and Fallback in a fluent and thread-safe manner. Inspired by .NET Polly.",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./backoff": {
      "import": "./dist/esm/backoff/index.js",
      "require": "./dist/backoff/index.js",
      "types": "./dist/backoff/index.d.ts"
    },
    "./breaker": {
      "import": "./dist/esm/breaker/index.js",
      "require": "./dist/breaker/index.js",
      "types": "./dist/breaker/index.d.ts"
    },
    "./errors": {
      "import": "./dist/esm/errors/index.js",
      "require": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "npm run compile",
    "test": "npm run test:unit && npm run test:fmt && npm run test:md",
    "test:cover": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "bench:watch": "vitest bench --watch",
    "bench:simple": "node src/simple-benchmark.js",
    "bench:compare": "./benchmark-comparison.sh",
    "test:fmt": "prettier --list-different \"src/**/*.ts\" \"*.md\"",
    "test:md": "remark -f readme.md -q",
    "fmt": "remark readme.md -f -o readme.md && prettier --write \"src/**/*.ts\" \"*.md\"",
    "compile": "rimraf dist && tsc && tsc -p tsconfig.esm.json",
    "watch": "rimraf dist && tsc --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/connor4312/cockatiel.git"
  },
  "keywords": [
    "circuit-breaker",
    "retry",
    "backoff",
    "jitter",
    "resilience",
    "timeout",
    "fallback",
    "fluent",
    "polly"
  ],
  "author": "Connor Peet <connor@peet.io>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/connor4312/cockatiel/issues"
  },
  "homepage": "https://github.com/connor4312/cockatiel#readme",
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/node": "^24.0.10",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "chai": "^5.2.0",
    "chai-as-promised": "^8.0.1",
    "chai-subset": "^1.6.0",
    "prettier": "^3.6.2",
    "remark-cli": "^12.0.1",
    "remark-toc": "^9.0.0",
    "remark-validate-links": "^13.1.0",
    "rimraf": "^6.0.1",
    "sinon": "^21.0.0",
    "sinon-chai": "^4.0.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "prettier": {
    "printWidth": 100,
    "arrowParens": "avoid",
    "singleQuote": true,
    "trailingComma": "all"
  }
}
